@model IEnumerable<Ticket>

@{
    ViewData["Title"] = "Lista zgłoszeń";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Zgłoszenia</h2>
    <a asp-action="Create" class="btn btn-primary">Dodaj zgłoszenie</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tytuł</th>
            <th>Status</th>
            <th>Utworzono</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ticket in Model)
        {
            <tr>
                <td>@ticket.Id</td>
                <td>@ticket.Title</td>
                <td>
                    @if (ticket.Status == TicketStatus.Open)
                    {
                        <span class="badge bg-success">Otwarty</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Zamknięty</span>
                    }
                </td>
                <td>@ticket.CreatedAt.ToString("g")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-info text-white">Szczegóły</a>
                </td>
            </tr>
        }
    </tbody>
</table>